{
  "name": "lazyaif",
  "version": "0.1.10",
  "type": "module",
  "description": "Analyze ai-factory plan statuses (fast/full) via TUI or CLI",
  "bin": {
    "lazyaif": "bin/lazyaif.ts"
  },
  "scripts": {
    "tui": "bun bin/lazyaif.ts tui",
    "plans": "bun bin/lazyaif.ts plans",
    "status": "bun bin/lazyaif.ts status",
    "test": "bun test",
    "build": "bun build --compile bin/lazyaif.ts --outfile lazyaif"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
